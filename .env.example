PORT=3500
JWT_SECRET=change-me-now
DB_PATH=./data/chatbot.db
GOOGLE_SERVICE_ACCOUNT_PATH=./google-service-account.json

# Optional AI classifier callback.
# AI_API_URL = base URL of the aria_agent service (the code appends /chat).
AI_API_URL=https://ai.e-glotech.com
AI_API_SECRET=change-me-must-match-aria_agent-SECRET_KEY
AI_API_TIMEOUT_MS=10000
# Leave AI_MODEL empty to let the AI service use its provider default
# (e.g. gpt-4o-mini for OpenAI). Only set it to force a specific model.
AI_MODEL=
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=200

# AI abuse protection (per IP + per device). 0 disables a window.
AI_RATE_PER_HOUR=30
AI_RATE_PER_DAY=150

# Max inbound chat message length (characters)
MAX_MESSAGE_LENGTH=1000

# Min matched keywords for a per-brand FAQ answer to fire (2 = best practice)
FAQ_MIN_KEYWORD_OVERLAP=2

# Database Manager
DB_MANAGER_USER=admin
DB_MANAGER_PASS=admin123
